<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ═══════════════════════════════════════════
             GROUPS
        ════════════════════════════════════════════ -->
        <record id="group_dashboard_user" model="res.groups">
            <field name="name">Dashboard User</field>
            <field name="category_id" ref="base.module_category_usability"/>
            <field name="comment">Can view dashboards assigned to their groups.</field>
        </record>

        <record id="group_dashboard_manager" model="res.groups">
            <field name="name">Dashboard Manager</field>
            <field name="category_id" ref="base.module_category_usability"/>
            <field name="implied_ids" eval="[(4, ref('group_dashboard_user'))]"/>
            <field name="comment">Can create, edit, and delete dashboards and components.</field>
        </record>

        <!-- ═══════════════════════════════════════════
             RECORD RULES
        ════════════════════════════════════════════ -->

        <!-- Dashboard Board: user sees only boards where they are in allowed groups -->
        <record id="rule_dashboard_board_user" model="ir.rule">
            <field name="name">Dashboard Board: user group filter</field>
            <field name="model_id" ref="model_dashboard_board"/>
            <field name="groups" eval="[(4, ref('group_dashboard_user'))]"/>
            <field name="domain_force">
                ['|',
                    ('group_ids', '=', False),
                    ('group_ids', 'in', user.groups_id.ids)
                ]
            </field>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Managers can do everything -->
        <record id="rule_dashboard_board_manager" model="ir.rule">
            <field name="name">Dashboard Board: manager full access</field>
            <field name="model_id" ref="model_dashboard_board"/>
            <field name="groups" eval="[(4, ref('group_dashboard_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- Multi-company rule -->
        <record id="rule_dashboard_board_company" model="ir.rule">
            <field name="name">Dashboard Board: multi-company</field>
            <field name="model_id" ref="model_dashboard_board"/>
            <field name="domain_force">
                ['|',
                    ('company_id', '=', False),
                    ('company_id', 'in', company_ids)
                ]
            </field>
        </record>

    </data>
</odoo>
