<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Chart Form View -->
    <record id="view_dashboard_chart_form" model="ir.ui.view">
        <field name="name">dashboard.chart.form</field>
        <field name="model">dashboard.chart</field>
        <field name="arch" type="xml">
            <form string="Chart Configuration">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="chart_type"/>
                            <field name="dashboard_id"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="color_scheme"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Data Configuration">
                        <group>
                            <field name="model_id"/>
                            <field name="model_name" invisible="1"/>
                            <field name="group_by_field_id"/>
                        </group>
                        <group>
                            <field name="aggregation_function"/>
                            <field name="measure_field_id" invisible="aggregation_function=='count'" required="aggregation_function!='count'" />
                        </group>
                    </group>
                    <group string="Filters">
                        <field name="domain" widget="domain" 
                               options="{'model': 'model_name'}" invisible="not model_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Chart List View -->
    <record id="view_dashboard_chart_tree" model="ir.ui.view">
        <field name="name">dashboard.chart.tree</field>
        <field name="model">dashboard.chart</field>
        <field name="arch" type="xml">
            <tree string="Charts">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="chart_type"/>
                <field name="model_id"/>
                <field name="dashboard_id"/>
            </tree>
        </field>
    </record>

    <!-- Chart Action -->
    <record id="action_dashboard_chart" model="ir.actions.act_window">
        <field name="name">Charts</field>
        <field name="res_model">dashboard.chart</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>