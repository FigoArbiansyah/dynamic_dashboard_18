<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard Form View -->
    <record id="view_dashboard_board_form" model="ir.ui.view">
        <field name="name">dashboard.board.form</field>
        <field name="model">dashboard.board</field>
        <field name="arch" type="xml">
            <form string="Dashboard">
                <header>
                    <button name="action_view_dashboard" type="object" 
                            string="View Dashboard" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="user_id"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Charts">
                            <field name="chart_ids">
                                <tree>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="chart_type"/>
                                    <field name="model_id"/>
                                    <field name="group_by_field_id" optional="hide"/>
                                    <field name="measure_field_id" optional="hide"/>
                                    <field name="aggregation_function"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Dashboard List View -->
    <record id="view_dashboard_board_tree" model="ir.ui.view">
        <field name="name">dashboard.board.tree</field>
        <field name="model">dashboard.board</field>
        <field name="arch" type="xml">
            <tree string="Dashboards">
                <field name="name"/>
                <field name="user_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="action_dashboard_board" model="ir.actions.act_window">
        <field name="name">Dashboards</field>
        <field name="res_model">dashboard.board</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>