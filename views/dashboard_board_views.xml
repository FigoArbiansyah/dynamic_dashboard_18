<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ── Tree View ── -->
        <record id="view_dashboard_board_list" model="ir.ui.view">
            <field name="name">dashboard.board.tree</field>
            <field name="model">dashboard.board</field>
            <field name="arch" type="xml">
                <tree string="Dashboards">
                    <field name="name"/>
                    <field name="menu_id"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="component_count"/>
                    <field name="cache_ttl"/>
                    <field name="is_active"/>
                </tree>
            </field>
        </record>

        <!-- ── Form View ── -->
        <record id="view_dashboard_board_form" model="ir.ui.view">
            <field name="name">dashboard.board.form</field>
            <field name="model">dashboard.board</field>
            <field name="arch" type="xml">
                <form string="Dashboard">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_components" type="object" class="oe_stat_button" icon="fa-th-large">
                                <field name="component_count" string="Components" widget="statinfo"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="e.g. Sales Performance..."/>
                            </h1>
                        </div>
                        <group>
                            <group string="Navigation &amp; Menu">
                                <field name="menu_parent_id" placeholder="Parent Menu..."/>
                                <field name="menu_id" readonly="1" help="The actual menu item linked to this dashboard."/>
                                <field name="dashboard_action_id" invisible="not dashboard_action_id" readonly="1"/>
                            </group>
                            <group string="Settings">
                                <field name="is_active" widget="boolean_toggle"/>
                                <field name="cache_ttl" placeholder="300"/>
                                <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                            </group>
                            <group string="Security">
                                <field name="group_ids" widget="many2many_tags" placeholder="Grant access to..."/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Components" name="components">
                                <field name="component_ids" context="{'default_board_id': active_id}">
                                    <tree editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="type"/>
                                        <field name="model_id"/>
                                        <field name="label"/>
                                        <field name="pos_w" string="Width"/>
                                        <field name="pos_h" string="Height"/>
                                        <field name="is_active"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ── Search View ── -->
        <record id="view_dashboard_board_search" model="ir.ui.view">
            <field name="name">dashboard.board.search</field>
            <field name="model">dashboard.board</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="menu_id"/>
                    <filter string="Active" name="active" domain="[('is_active','=',True)]"/>
                    <filter string="Inactive" name="inactive" domain="[('is_active','=',False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Company" name="by_company" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ── Action ── -->
        <record id="action_dashboard_board" model="ir.actions.act_window">
            <field name="name">Dashboards</field>
            <field name="res_model">dashboard.board</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_dashboard_board_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first dynamic dashboard!
                </p>
            </field>
        </record>

    </data>
</odoo>
