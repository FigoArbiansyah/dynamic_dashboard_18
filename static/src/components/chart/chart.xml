<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dynamic_dashboard.ChartComponent">
        <div class="o_chart_container card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    <t t-esc="props.chartName"/>
                </h5>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-sm btn-outline-secondary"
                            t-on-click="onRefresh"
                            title="Refresh">
                        <i class="fa fa-refresh"/>
                    </button>
                    <button class="btn btn-sm btn-outline-primary"
                            t-on-click="onEdit"
                            title="Edit">
                        <i class="fa fa-edit"/>
                    </button>
                </div>
            </div>
            <div class="card-body position-relative" t-attf-id="card-body-{{props.chartId}}" style="height: 500px;">
                <!-- Loading State -->
                <div t-if="state.loading"
                     class="position-absolute top-50 start-50 translate-middle">
                    <i class="fa fa-spinner fa-spin fa-2x text-muted"/>
                </div>

                <!-- Error State -->
                <div t-elif="state.error"
                     class="position-absolute top-50 start-50 translate-middle text-center">
                    <i class="fa fa-exclamation-triangle fa-2x text-warning mb-2"/>
                    <p class="text-muted">
                        <t t-esc="state.error"/>
                    </p>
                </div>

                <!-- Chart Canvas -->
<!--                <canvas t-else="" t-attf-id="canvas-chart-{{props.chartId}}" width="300px"/>-->
            </div>
        </div>
    </t>
</templates>